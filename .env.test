NODE_ENV=test
PORT=3333

#auth
JWT_SECRET=keyPontoSeguroApi

# nome do projeto para o container do docker
COMPOSE_PROJECT_NAME=ponto_seguro_api

# variaveis para o compose(database)
DB_USER=docker
DB_PASSWORD=docker
DB_NAME=e2e-test

# string de conexão do prisma com database
DATABASE_URL=postgresql://docker:docker@localhost:5432/e2e-test?schema=test
